# Senha do usuário SA do SQL Server
# Requisitos: mínimo 8 caracteres com maiúscula, minúscula, número e símbolo
SA_PASSWORD=TrocarPor_SenhaForte123!

# Connection string da API — sobrescreve a default do appsettings.json
# Deve usar a mesma senha definida em SA_PASSWORD acima
ConnectionStrings__Default=Server=localhost,1433;Database=Catalogo;User Id=sa;Password=TrocarPor_SenhaForte123!;TrustServerCertificate=True;Encrypt=False
